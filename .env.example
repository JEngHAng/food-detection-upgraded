# ══════════════════════════════════════════════════════
# .env — ตั้งค่า Environment Variables
# copy ไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับเครื่อง
# ══════════════════════════════════════════════════════

# ── Flask Server ─────────────────────────────────────
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0
SECRET_KEY=change-me-in-production

# ── Database ─────────────────────────────────────────
DB_PATH=food_detection.db

# ── YOLOv8 ───────────────────────────────────────────
CONFIDENCE=0.4

# ── HX711 Load Cell GPIO ─────────────────────────────
HX711_DOUT=5       # GPIO5 (Pin 29)
HX711_SCK=6        # GPIO6 (Pin 31)

# ── Load Cell Calibration ─────────────────────────────
# copy ค่าเหล่านี้จากผลลัพธ์ของ test_loadcell.py:
#
#   ── copy ค่านี้ไปใส่ใน food_detection ──────────
#   LOADCELL_DT_PIN       = 5
#   LOADCELL_SCK_PIN      = 6
#   LOADCELL_ZERO_RAW     = <ค่าที่ได้>
#   LOADCELL_SCALE_FACTOR = <ค่าที่ได้>
#   ────────────────────────────────────────────────
#
HX711_SCALE=420.0              # scale_factor จาก calibration
LOADCELL_ZERO_RAW=0            # zero_raw จาก calibration (no-load)
LOADCELL_SCALE_FACTOR=420.0    # เหมือน HX711_SCALE

# ── Load Cell Tuning ─────────────────────────────────
HX711_READ_DELAY=0.05          # หน่วง (วินาที) ระหว่างแต่ละอ่าน
